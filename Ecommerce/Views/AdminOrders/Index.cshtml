@model List<Ecommerce.Models.Order>

<h2>All Orders</h2>

<table class="table">
    <thead>
        <tr>
            <th>Order Id</th>
            <th>User</th>
            <th>Total</th>
            <th>Status</th>
            <th>Change</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.Id</td>
                <td>@order.UserId</td>
                <td>@order.Total</td>
                <td>@order.Status</td>
                <td>
                    <a asp-action="UpdateStatus" asp-route-id="@order.Id" asp-route-status="Processing" class="btn btn-warning">Processing</a>
                    <a asp-action="UpdateStatus" asp-route-id="@order.Id" asp-route-status="Completed" class="btn btn-success">Completed</a>
                </td>
            </tr>
        }
    </tbody>
</table>