@model Ecommerce.Models.Product

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Product";
    ViewData["PageTitle"] = "Edit Product";
    ViewData["BreadcrumbParent"] = "Products";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "Products");
    ViewData["BreadcrumbCurrent"] = "Edit";
}

<div class="admin-card admin-form-card">
    <div class="admin-card-header">
        <span class="card-title">✏️ Edit Product</span>
        <a asp-action="Index" class="btn-admin-secondary">← Back to Products</a>
    </div>
    <div class="admin-card-body">
        <form asp-action="Edit" enctype="multipart/form-data" class="admin-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-row">
                <div class="form-field">
                    <label asp-for="Name">Product Name</label>
                    <input asp-for="Name" />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>
                <div class="form-field">
                    <label asp-for="Price">Price (EGP)</label>
                    <input asp-for="Price" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="field-error"></span>
                </div>
            </div>

            <div class="form-field">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" rows="3"></textarea>
                <span asp-validation-for="Description" class="field-error"></span>
            </div>

            <div class="form-row">
                <div class="form-field">
                    <label>Current Image</label>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="img-preview-card">
                            <img src="~/images/@Model.ImageUrl" alt="Current product image" />
                            <span class="img-label">Current image</span>
                        </div>
                    }
                    else
                    {
                        <div class="no-image-placeholder">
                            <span style="font-size:28px;">📷</span>
                            <span>No image</span>
                        </div>
                    }
                    <div style="margin-top:10px;">
                        <label style="font-size:12px;color:#6b7280;font-weight:500;margin-bottom:6px;display:block;">Replace with new image</label>
                        <input type="file" asp-for="ImageFile" accept="image/*" />
                        <span asp-validation-for="ImageUrl" class="field-error"></span>
                    </div>
                </div>
                <div class="form-field">
                    <label asp-for="CategoryId">Category</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.CategoryId"></select>
                    <span asp-validation-for="CategoryId" class="field-error"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-admin-primary">✓ Save Changes</button>
                <a asp-action="Index" class="btn-admin-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
