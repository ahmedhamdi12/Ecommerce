@model Ecommerce.Models.Product

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Delete Product";
    ViewData["PageTitle"] = "Delete Product";
    ViewData["BreadcrumbParent"] = "Products";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "Products");
    ViewData["BreadcrumbCurrent"] = "Delete";
}

<div class="danger-zone-card">
    <div class="danger-header">
        <div class="danger-icon">⚠️</div>
        <div>
            <h2 class="danger-title">Delete Product</h2>
            <p class="danger-sub">This action is permanent and cannot be undone.</p>
        </div>
    </div>

    <div class="danger-detail">
        <dl>
            <dt>Product Name</dt>
            <dd>@Model.Name</dd>
            <dt>Price</dt>
            <dd>@Model.Price.ToString("N2") EGP</dd>
            <dt>Category</dt>
            <dd>@Model.Category?.Name</dd>
            <dt>Description</dt>
            <dd>@Model.Description</dd>
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <dt>Image</dt>
                <dd>
                    <img src="~/images/@Model.ImageUrl" style="width:80px;height:80px;object-fit:cover;border-radius:8px;margin-top:6px;" />
                </dd>
            }
        </dl>
    </div>

    <form asp-action="Delete" style="display:flex;align-items:center;gap:12px;">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn-admin-danger">🗑️ Yes, Delete Product</button>
        <a asp-action="Index" class="btn-admin-secondary">Cancel</a>
    </form>
</div>
