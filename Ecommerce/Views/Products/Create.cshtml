@model Ecommerce.Models.Product

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Create Product";
    ViewData["PageTitle"] = "New Product";
    ViewData["BreadcrumbParent"] = "Products";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "Products");
    ViewData["BreadcrumbCurrent"] = "Create";
}

<div class="admin-card admin-form-card">
    <div class="admin-card-header">
        <span class="card-title">📦 Add New Product</span>
        <a asp-action="Index" class="btn-admin-secondary">← Back to Products</a>
    </div>
    <div class="admin-card-body">
        <form asp-action="Create" enctype="multipart/form-data" class="admin-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-row">
                <div class="form-field">
                    <label asp-for="Name">Product Name</label>
                    <input asp-for="Name" placeholder="e.g. Blue Denim Jacket" />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>
                <div class="form-field">
                    <label asp-for="Price">Price (EGP)</label>
                    <input asp-for="Price" type="number" step="0.01" placeholder="e.g. 299.99" />
                    <span asp-validation-for="Price" class="field-error"></span>
                </div>
            </div>

            <div class="form-field">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" rows="3" placeholder="Short product description..."></textarea>
                <span asp-validation-for="Description" class="field-error"></span>
            </div>

            <div class="form-row">
                <div class="form-field">
                    <label>Product Image</label>
                    <input type="file" asp-for="ImageFile" accept="image/*" />
                </div>
                <div class="form-field">
                    <label asp-for="CategoryId">Category</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.CategoryId">
                        <option value="">— Select Category —</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="field-error"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-admin-primary">✓ Create Product</button>
                <a asp-action="Index" class="btn-admin-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
