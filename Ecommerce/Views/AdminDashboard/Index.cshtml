@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
    ViewData["PageTitle"] = "Dashboard";
}

<!-- Stat Cards -->
<div class="stat-cards">
    <div class="stat-card orders">
        <div class="stat-icon">🛍️</div>
        <div class="stat-value">@ViewBag.TotalOrders</div>
        <div class="stat-label">Total Orders</div>
    </div>
    <div class="stat-card revenue">
        <div class="stat-icon">💰</div>
        <div class="stat-value">@ViewBag.TotalRevenue <span style="font-size:16px;font-weight:500;">EGP</span></div>
        <div class="stat-label">Total Revenue</div>
    </div>
    <div class="stat-card users">
        <div class="stat-icon">👤</div>
        <div class="stat-value">@ViewBag.TotalUsers</div>
        <div class="stat-label">Registered Users</div>
    </div>
</div>

<!-- Charts Row -->
<div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:28px;">

    <div class="chart-card">
        <div class="chart-title">📈 System Overview</div>
        <canvas id="ordersChart" height="80"></canvas>
    </div>

    <div class="admin-card">
        <div class="admin-card-header">
            <span class="card-title">⚡ Quick Actions</span>
        </div>
        <div class="admin-card-body" style="padding:16px;">
            <div style="display:flex;flex-direction:column;gap:10px;">
                <a asp-controller="Products" asp-action="Create" class="btn-admin-primary" style="justify-content:center;">
                    ＋ Add Product
                </a>
                <a asp-controller="Categories" asp-action="Create" class="btn-admin-primary" style="justify-content:center;background:#8b5cf6;color:#fff;">
                    ＋ Add Category
                </a>
                <a asp-controller="AdminOrders" asp-action="Index" class="btn-admin-secondary" style="justify-content:center;">
                    📋 View All Orders
                </a>
                <a asp-controller="Shop" asp-action="Index" class="btn-admin-secondary" style="justify-content:center;">
                    🏪 Visit Storefront
                </a>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var ctx = document.getElementById('ordersChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Orders', 'Users'],
                datasets: [{
                    label: 'Count',
                    data: [@ViewBag.TotalOrders, @ViewBag.TotalUsers],
                    backgroundColor: ['rgba(59,130,246,0.7)', 'rgba(201,168,76,0.7)'],
                    borderColor:     ['#3b82f6', '#c9a84c'],
                    borderWidth: 2,
                    borderRadius: 8,
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { precision: 0 },
                        grid: { color: 'rgba(0,0,0,0.05)' }
                    },
                    x: {
                        grid: { display: false }
                    }
                }
            }
        });
    </script>
}