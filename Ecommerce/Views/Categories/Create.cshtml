@model Ecommerce.Models.Category

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = Localizer["CreateCategory"];
    ViewData["PageTitle"] = Localizer["CreateCategory"];
    ViewData["BreadcrumbParent"] = Localizer["Categories"];
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "Categories");
    ViewData["BreadcrumbCurrent"] = Localizer["Create"];
}

<div class="admin-card admin-form-card">
    <div class="admin-card-header">
        <span class="card-title">🗂️ @Localizer["CreateCategory"]</span>
        <a asp-action="Index" class="btn-admin-secondary">← @Localizer["BackToList"]</a>
    </div>
    <div class="admin-card-body">
        <form asp-action="Create" class="admin-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-field">
                <label asp-for="Name">@Localizer["CategoryName"]</label>
                <input asp-for="Name" placeholder="..." />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-admin-primary">✓ @Localizer["CreateCategory"]</button>
                <a asp-action="Index" class="btn-admin-secondary">@Localizer["Cancel"]</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
