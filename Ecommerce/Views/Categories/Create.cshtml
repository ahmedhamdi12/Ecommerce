@model Ecommerce.Models.Category

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Create Category";
    ViewData["PageTitle"] = "New Category";
    ViewData["BreadcrumbParent"] = "Categories";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "Categories");
    ViewData["BreadcrumbCurrent"] = "Create";
}

<div class="admin-card admin-form-card">
    <div class="admin-card-header">
        <span class="card-title">🗂️ Add New Category</span>
        <a asp-action="Index" class="btn-admin-secondary">← Back to Categories</a>
    </div>
    <div class="admin-card-body">
        <form asp-action="Create" class="admin-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-field">
                <label asp-for="Name">Category Name</label>
                <input asp-for="Name" placeholder="e.g. Electronics, Clothing, Shoes..." />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-admin-primary">✓ Create Category</button>
                <a asp-action="Index" class="btn-admin-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
