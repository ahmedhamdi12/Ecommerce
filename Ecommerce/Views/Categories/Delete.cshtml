@model Ecommerce.Models.Category

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Delete Category";
    ViewData["PageTitle"] = "Delete Category";
    ViewData["BreadcrumbParent"] = "Categories";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "Categories");
    ViewData["BreadcrumbCurrent"] = "Delete";
}

<div class="danger-zone-card">
    <div class="danger-header">
        <div class="danger-icon">⚠️</div>
        <div>
            <h2 class="danger-title">Delete Category</h2>
            <p class="danger-sub">This action is permanent and cannot be undone.</p>
        </div>
    </div>

    <div class="danger-detail">
        <dl>
            <dt>Category Name</dt>
            <dd>@Model.Name</dd>
        </dl>
    </div>

    <form asp-action="Delete" style="display:flex;align-items:center;gap:12px;">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn-admin-danger">🗑️ Yes, Delete Category</button>
        <a asp-action="Index" class="btn-admin-secondary">Cancel</a>
    </form>
</div>
