@model List<Ecommerce.Models.Product>
@{
    ViewData["Title"] = "Index";
}

<form method="get" class="row mb-4">

    <!-- 🔍 Search -->
    <div class="col-md-4">
        <input type="text" name="search" class="form-control" placeholder="Search..." />
    </div>

    <!-- 🏷️ Category Filter -->
    <div class="col-md-4">
        <select name="categoryId" class="form-control">
            <option value="">All Categories</option>
            @foreach (var cat in ViewBag.Categories)
            {
                <option value="@cat.Id">@cat.Name</option>
            }
        </select>
    </div>

    <div class="col-md-4">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
    </div>

</form>
<h1>Products</h1>
<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card">
                <img src="~/images/@item.ImageUrl" class="card-img-top" style="height:200px; object-fit:cover;" />

                <div class="card-body">
                    <h5>@item.Name</h5>
                    <p>@item.Price EGP</p>
                    <p>@item.Category.Name</p>

                    <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.Id" class="btn btn-success">
                        Add To Cart
                    </a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary">
                        Details
                    </a>
                </div>
            </div>
        </div>
    }
</div>
<div class="d-flex justify-content-center mt-4">

    @for (int i = 1; i <= ViewBag.TotalPages; i++)
    {
        <a class="btn btn-outline-primary mx-1 @(i == ViewBag.CurrentPage ? "active" : "")"
           href="@Url.Action("Index", new { 
                page = i, 
                search = Context.Request.Query["search"], 
                categoryId = Context.Request.Query["categoryId"] 
            })">
            @i
        </a>
    }

</div>
