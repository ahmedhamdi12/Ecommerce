@model Ecommerce.Models.Product
@{
    ViewData["Title"] = "Details";
}

<div class="row">
    <div class="col-md-6">
        <img src="~/images/@Model.ImageUrl" style="width:100%" />
    </div>

    <div class="col-md-6">
        <h2>@Model.Name</h2>
        <h4>@Model.Price EGP</h4>
        <p>@Model.Description</p>
        <p><strong>Category:</strong> @Model.Category.Name</p>

        <button class="btn btn-success">Add To Cart</button>
    </div>
</div>

